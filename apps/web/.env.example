# VikraHub Public Website Environment Variables
# Copy this file to .env.local and fill in the values

# ── Required ────────────────────────────────────────────

# Backend API URL (inlined at build time, visible to browser)
NEXT_PUBLIC_API_URL=https://api.vikrahub.com

# Site URL (used for canonical links and metadata)
NEXT_PUBLIC_SITE_URL=https://www.vikrahub.com

# Search engine verification tokens
# Google Search Console token value (content for <meta name="google-site-verification" ...>)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster token value (content for <meta name="msvalidate.01" ...>)
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ── Optional ────────────────────────────────────────────

# Internal API URL for server-side rendering (Docker/internal networking)
# Falls back to NEXT_PUBLIC_API_URL if not set
# INTERNAL_API_URL=http://backend:8000
